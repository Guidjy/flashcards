venv/
env/
ENV/
.venv/
.env/

# Environment variables
.env
*.env

# IDE/editor specific
.vscode/
.idea/
*.sublime-workspace
*.sublime-project

# Mac/Linux/Windows system files
.DS_Store
Thumbs.db

# Logs
*.log

# Coverage and test results
htmlcov/
.coverage
.tox/
.pytest_cache/
nosetests.xml
coverage.xml
*.cover
*.log

